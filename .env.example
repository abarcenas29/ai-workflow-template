# Playwright Configuration Environment Variables
# Copy this file to .env and customize for your project

# Base URL for web projects (uncomment and set if testing web applications)
# BASE_URL=http://localhost:3000

# Run tests in headless mode (true/false)
# Set to false for VSCode debugging with visible browser
HEADLESS=false

# Add delay between actions in milliseconds (useful for debugging)
# SLOW_MO=100

# API Base URL for API testing projects
# API_BASE_URL=http://localhost:8080/api

# Custom Playwright configuration
# PWDEBUG=console

# CI mode (automatically set in CI environments)
# CI=true
