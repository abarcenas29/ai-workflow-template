{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "ddg-search": {
       "type": "local",
       "command": ["npx", "-y", "ddg-mcp-search"],
       "enabled": true
     },
    "github": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": "node",
      "args": ["scripts/mcp/playwright-mcp-launcher.js"],
      "env": {
        "HEADLESS": "$HEADLESS",
        "SLOW_MO": "$SLOW_MO",
        "VIEWPORT": "$VIEWPORT"
      },
      "enabled": true
    },
    "example-server": {
      "type": "local",
      "command": ["npx", "-y", "your-mcp-package"],
      "enabled": false
    },
    "example-remote": {
      "type": "remote",
      "url": "https://your-mcp-server.com/mcp",
      "enabled": false
    }
  },
  "permission": {
    "ddg-search_*": "allow",
    "github_*": "allow",
    "mcp-everything_*": "allow",
    "playwright_*": "allow"
  }
}