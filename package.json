{
  "name": "@abarcenas/ai-workflow-template",
  "version": "1.10.0",
  "description": "A comprehensive template repository for AI-assisted development workflows using GitHub Copilot. This template provides a structured approach to leveraging AI assistance through pre-configured skills, prompts, agents, and coding standards.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "prepare": "husky",
    "sync": "node ./scripts/sync.js",
    "postinstall": "node ./scripts/sync.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abarcenas29/ai-workflow-template.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/abarcenas29/ai-workflow-template/issues"
  },
  "homepage": "https://github.com/abarcenas29/ai-workflow-template#readme",
  "files": [
    ".agents/",
    ".github/workflows/",
    "scripts/",
    "AGENTS.md",
    "opencode.mcp.example.json"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.2",
    "husky": "^9.0.0"
  }
}
